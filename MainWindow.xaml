<Window x:Class="NordFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NordFlow"
        mc:Ignorable="d"
        Title="NordFlow ERP - Customer Invoice Management" 
        Height="600" Width="900">

    <!-- ========================================
         MAIN LAYOUT - Contains Customer and Invoice sections
         ======================================== -->
    <Grid>
        
        <!-- ========================================
             CUSTOMER SECTION - Top section for customer management
             ======================================== -->
        <StackPanel Margin="20" VerticalAlignment="Top">
            <!-- Section Header -->
            <TextBlock Text="CUSTOMERS" 
                       FontWeight="Bold" 
                       FontSize="20" 
                       HorizontalAlignment="Left"
                       Margin="0,0,0,20"/>
            
            <!-- Customer Name Input -->
            <TextBox x:Name="NameInput"
                     Width="300"
                     Height="35"
                     Margin="0,0,0,15"
                     FontSize="14"
                     HorizontalAlignment="Left"/>
            
            <!-- Main Action Button (Add/Edit) -->
            <Button Content="ADD CUSTOMER / UPDATE" 
                    Width="200"
                    Height="40"
                    Click="MyButton_Click"
                    FontSize="14"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,15"/>
            
            <!-- Customer List -->
            <ListBox x:Name="CustomerListBox"
                     Width="350"
                     Height="140"
                     Margin="0,0,0,15"
                     DisplayMemberPath="Name"
                     SelectionMode="Single"/>
            
            <!-- Customer Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="EDIT" 
                        Click="EditButton_Click" 
                        Width="90" 
                        Height="35" 
                        Margin="0,0,10,0"/>
                <Button Content="DELETE" 
                        Click="DeleteButton_Click" 
                        Width="90" 
                        Height="35"/>
            </StackPanel>
        </StackPanel>

        <!-- ========================================
             INVOICE SECTION - Bottom section for invoice management
             ======================================== -->
        <StackPanel Margin="20,0,20,20" VerticalAlignment="Bottom">
            <!-- Section Header -->
            <TextBlock Text="INVOICES" 
                       FontWeight="Bold" 
                       FontSize="20" 
                       HorizontalAlignment="Left"
                       Margin="0,0,0,15"/>
            
            <!-- Invoice List -->
            <ListBox x:Name="InvoiceListBox" 
                     Height="110"
                     Margin="0,0,0,15">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <!-- Customer Name -->
                            <TextBlock Text="{Binding Customer.Name}" 
                                       FontWeight="Bold" 
                                       Width="120"/>
                            <!-- Amount -->
                            <TextBlock Text="{Binding Amount, StringFormat={}{0:C}}" 
                                       FontWeight="SemiBold" 
                                       Foreground="DarkGreen"
                                       Width="100"/>
                            <!-- Status -->
                            <TextBlock Text="{Binding Status}" 
                                       Margin="10,0,0,0"
                                       FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Unpaid">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                <Setter Property="Foreground" Value="DarkGreen"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Date -->
                            <TextBlock Text="{Binding Date, StringFormat=dd/MM HH:mm}" 
                                       Foreground="Gray" 
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <!-- Invoice Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="NEW INVOICE" 
                        Click="NewInvoice_Click" 
                        Width="110" 
                        Height="40"
                        Margin="0,0,10,0"/>
                <Button Content="PAY" 
                        Click="PayInvoice_Click" 
                        Width="90" 
                        Height="40"
                        Margin="0,0,10,0"/>
                <Button Content="DELETE" 
                        Click="DeleteInvoice_Click" 
                        Width="90" 
                        Height="40"/>
            </StackPanel>
        </StackPanel>
        
        
                <!-- ========================================
             PRODUCT SECTION - Middle section for product management
             ======================================== -->
        <StackPanel Margin="400,20,20,170" VerticalAlignment="Top">
            <!-- Section Header -->
            <TextBlock Text="PRODUCTS"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Right"
                       Margin="0,0,0,20"/>

            <!-- Product Name Input -->
            <TextBox x:Name="ProductNameInput"
                     Width="200"
                     Height="35"
                     Margin="0,0,0,10"
                     FontSize="14"
                     HorizontalAlignment="Right"/>

            <!-- Product Price Input -->
            <TextBox x:Name="ProductPriceInput"
                     Width="200"
                     Height="35"
                     Margin="0,0,0,10"
                     FontSize="14"
                     HorizontalAlignment="Right"/>

            <!-- Product Stock Input -->
            <TextBox x:Name="ProductStockInput"
                     Width="200"
                     Height="35"
                     Margin="0,0,0,15"
                     FontSize="14"
                     HorizontalAlignment="Right"/>

            <!-- Product Action Button -->
            <Button Content="ADD PRODUCT"
                    Width="160"
                    Height="40"
                    Click="AddProduct_Click"
                    FontSize="14"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,15"/>

            <!-- Product List -->
            <ListBox x:Name="ProductListBox"
                     Width="280"
                     Height="140"
                     HorizontalAlignment="Right"/>
        </StackPanel>

        
    </Grid>
</Window>