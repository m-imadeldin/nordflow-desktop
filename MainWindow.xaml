<Window x:Class="NordFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NordFlow"
        mc:Ignorable="d"
        Title="NordFlow" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock x:Name="WelcomeText"
                   Text="Welcome to NordFLow"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="24" />
       
        <Button Content="Click Me"
                Width="120"
                Height="35" 
                Click="MyButton_Click" />
        
        <ListBox x:Name="CustomerListBox"
                 Width="250"
                 Height="120"
                 Margin="0,20,0,0"
                 DisplayMemberPath="Name" />
        
        <TextBox x:Name="NameInput"
                 Width="200"
                 Height="30"
                 Margin="0,10,0,10" />
         
        <Button Content="Ta bort" Click="DeleteButton_Click" />
        <Button Content="Redigera" Click="EditButton_Click" />
        
        </StackPanel>
                   
    </Grid>
</Window>
